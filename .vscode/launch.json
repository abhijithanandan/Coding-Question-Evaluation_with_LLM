{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Evaluate Q17 (OpenAI gpt-5.4, dry-run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/evaluate_coding.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "17",
                "--provider",
                "openai",
                "--model",
                "gpt-5.4",
                "--dry-run"
            ],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            },
            "justMyCode": true
        },
        {
            "name": "Evaluate Q17 (OpenAI gpt-5.4-mini, dry-run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/evaluate_coding.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "17",
                "--provider",
                "openai",
                "--model",
                "gpt-5.4-mini",
                "--dry-run"
            ],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            },
            "justMyCode": true
        },
        {
            "name": "Evaluate Q17 (Gemini, dry-run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/evaluate_coding.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "17",
                "--provider",
                "google",
                "--model",
                "gemini-2.5-flash",
                "--dry-run"
            ],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            },
            "justMyCode": true
        },
        {
            "name": "Evaluate single-file (OpenAI gpt-5.4)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/evaluate_coding.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "17",
                "--provider",
                "openai",
                "--model",
                "gpt-5.4-mini",
                "--single-file",
                "${workspaceFolder}/data/Submissions_17/cb.ai.u4aid24002.py"
            ],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            },
            "justMyCode": true
        },
        {
            "name": "Python: Debug current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            },
            "justMyCode": true
        }
    ]
}