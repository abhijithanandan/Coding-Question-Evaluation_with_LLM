{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug evaluate_coding.py (dry-run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/evaluate_coding.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "29",
                "--provider",
                "openai",
                "--model",
                "gpt-5-2025-08-07",
                "--dry-run"
            ],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            },
            "justMyCode": true
        },
        {
            "name": "Python: Debug evaluate_coding.py (single-file)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/evaluate_coding.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "args": [
                "29",
                "--provider",
                "openai",
                "--model",
                "gpt-5-2025-08-07",
                "--single-file",
                "${workspaceFolder}/data/Submissions_29/cb.ai.u4aid23036.cu"
            ],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            },
            "justMyCode": true
        },
        {
            "name": "Python: Debug current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            },
            "justMyCode": true
        }
    ]
}